        "name": "domain",
        "options": [],
        "query": "SELECT DISTINCT target_domain FROM runs ORDER BY 1",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {"from": "now-30d", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
